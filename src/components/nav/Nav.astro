---
import NavButton from "./NavButton.astro";
import LabeledItem from "../LabeledItem.astro";
---
<div class="nav-wrapper">
  <nav>
    <a href="/"><h1>kigawa's portfolio</h1></a>
    <ul>
      <NavButton title="about"/>
      <NavButton title="skill"/>
      <NavButton title="experience"/>
      <NavButton title="products"/>
    </ul>
    <details class="footer-toggle mobile">
      <summary>連絡先</summary>
      <footer>
        <LabeledItem text="twitter">
          <a href="https://twitter.com/kigawa20" target="_blank">@kigawa20</a>
        </LabeledItem>
        <LabeledItem text="github">
          <a href="https://github.com/kigawa01" target="_blank">kigawa01</a>
        </LabeledItem>
        <LabeledItem text="email">
          <p>contact@kigawa.net</p>
        </LabeledItem>
        <LabeledItem text="sourcecode">
          <a href="https://github.com/kigawa01/portfolio" target="_blank">https://github.com/kigawa01/portfolio</a>
        </LabeledItem>
      </footer>
    </details>
    <footer class="desktop">
      <LabeledItem text="twitter">
        <a href="https://twitter.com/kigawa20" target="_blank">@kigawa20</a>
      </LabeledItem>
      <LabeledItem text="github">
        <a href="https://github.com/kigawa01" target="_blank">kigawa01</a>
      </LabeledItem>
      <LabeledItem text="email">
        <p>contact@kigawa.net</p>
      </LabeledItem>
      <LabeledItem text="sourcecode">
        <a href="https://github.com/kigawa01/portfolio" target="_blank">https://github.com/kigawa01/portfolio</a>
      </LabeledItem>
    </footer>
  </nav>
</div>
<style>
  .nav-wrapper {
    height: 100vh;
    padding: 10px 0 10px 10px;
    width: 500px;
    box-sizing: border-box;
    display: flex;
    flex-shrink: 0;
  }
  nav {
    background-color: var(--mcolor-secondary-container);
    color: var(--mcolor-on-secondary-container);
    width: 100%;
    border-radius: 8px;
    border: 2px solid var(--mcolor-outline);
    padding: 28px;
    display: flex;
    flex-direction: column;
  }
  ul {
    margin: 60px 0 0 0;
    font-size: 1.5rem;
    flex: 1;
  }
  a {
    text-decoration: underline;
  }
  .footer-toggle > footer {
    display: block;
  }
  .mobile {
    display: none;
  }
  .desktop {}
  @media (max-width: 1000px) {
    .mobile {
      display: block;
    }
    .desktop {
      display: none;
    }
    .nav-wrapper {
      height: auto;
      width: 100%;
      padding: 10px 10px 0 10px;
    }
    nav {
      padding: 16px 20px;
    }
    h1 {
      font-size: 1.2rem;
    }
    ul {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
      margin: 12px 0 0 0;
      font-size: 1rem;
      flex: unset;
    }
    footer {
      margin-top: 8px;
      font-size: 0.85rem;
    }
    .footer-toggle {
      margin-top: 12px;
    }
    .footer-toggle > summary {
      display: list-item;
      cursor: pointer;
      font-size: 0.9rem;
      padding: 4px 0;
    }
  }
</style>